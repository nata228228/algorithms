#include <iostream>
#include <vector>
#include <queue>
#include <algorithm>

//обход графа, вывод порядка
void bfs(const std::vector<std::vector<int>>& graph, int start) {
    int n = graph.size();
    std::vector<bool> visited(n, false);
    std::queue<int> q;
    
    visited[start] = true;
    q.push(start);
    
    while (!q.empty()) {
        int current = q.front();
        q.pop();
        std::cout << current << " ";
        
        for (int neighbor : graph[current]) {
            if (!visited[neighbor]) {
                visited[neighbor] = true;
                q.push(neighbor);
            }
        }
    }
    std::cout << std::endl;
}

//возврат расстояний
std::vector<int> bfs_distances(const std::vector<std::vector<int>>& graph, int start) {
    int n = graph.size();
    std::vector<int> dist(n, -1);
    std::queue<int> q;
    
    dist[start] = 0;
    q.push(start);
    
    while (!q.empty()) {
        int current = q.front();
        q.pop();
        
        for (int neighbor : graph[current]) {
            if (dist[neighbor] == -1) {
                dist[neighbor] = dist[current] + 1;
                q.push(neighbor);
            }
        }
    }
    
    return dist;
}

//поиск кратчайшего пути
std::vector<int> bfs_shortest_path(const std::vector<std::vector<int>>& graph, int start, int end) {
    int n = graph.size();
    std::vector<int> parent(n, -1);
    std::queue<int> q;
    
    parent[start] = start;
    q.push(start);
    
    while (!q.empty()) {
        int current = q.front();
        q.pop();
        
        if (current == end) break;
        
        for (int neighbor : graph[current]) {
            if (parent[neighbor] == -1) {
                parent[neighbor] = current;
                q.push(neighbor);
            }
        }
    }
    
    std::vector<int> path;
    if (parent[end] != -1) {
        for (int v = end; v != start; v = parent[v]) {
            path.push_back(v);
        }
        path.push_back(start);
        std::reverse(path.begin(), path.end());
    }
    
    return path;
}
